# Google AI Studio
GOOGLE_API_KEY=your-google-ai-studio-api-key

# LLM Configuration
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMP=0.25

# MAS Behavior
MAS_VERBOSE=1
MAS_MAX_TURNS=20
MAS_MAX_GLOBAL_TOOL_CALLS=60
MAS_MAX_P2P_HOPS=4

# Run Control
# POLICY: strict | gentle | free
POLICY=strict
# PROMPT_CONDITION: debate | delphi | ptow
PROMPT_CONDITION=debate
SEED=42

# Neo4j AuraDB (optional — for KG-enhanced fault queries)
# Leave unset to use local tep_knowledge fallback
# NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-auradb-password

# Paths (optional overrides)
# DB_PATH=sqlite:///tep_database.db
# PDF_DIR=TEP_docs
