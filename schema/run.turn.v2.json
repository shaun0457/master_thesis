{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "required": ["schema", "run_id", "turn_index", "role", "message", "intent", "action", "ts"],
  "properties": {
    "schema":      {"type": "string"},
    "run_id":      {"type": "string"},
    "turn_index":  {"type": "integer"},
    "role":        {"type": "string"},
    "message":     {"type": "string"},
    "intent":      {"type": "string"},
    "action":      {"type": "object"},
    "ts":          {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
